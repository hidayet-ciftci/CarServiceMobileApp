{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "CarRentalProjectJwtSecretKey1234567890",
    "Issuer": "CarRentalProject",
    "Audience": "CarRentalProjectUsers"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5430;Database=carRental;Username=postgres;Password=123456"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
